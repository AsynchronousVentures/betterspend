{$BETTERSPEND_DOMAIN} {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:4001
  }

  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }
}

files.{$BETTERSPEND_DOMAIN} {
  encode zstd gzip

  reverse_proxy minio:9000 {
    header_up Host {host}
  }
}
