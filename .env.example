# Database
DATABASE_URL=postgresql://betterspend:betterspend@localhost:5433/betterspend

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# S3 / MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=betterspend
MINIO_REGION=us-east-1

# Legacy S3 aliases are still accepted by the API.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=betterspend
S3_REGION=us-east-1

# Auth
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-hex-32
AI_CREDENTIAL_ENCRYPTION_KEY=change-me-use-openssl-rand-base64-32

# URLs
# Development: use http://localhost:4001 (API) and http://localhost:3100 (web)
# Production with Caddy path-based routing: all three point to the same domain
API_PORT=4001
API_URL=http://localhost:4001
WEB_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:4001
