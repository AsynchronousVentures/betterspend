# Copy this file to /opt/betterspend/.env.production on the server.
# Keep the server copy out of git.

# Public domains
BETTERSPEND_DOMAIN=example.com
MINIO_PUBLIC_ENDPOINT=https://files.example.com

# Images are normally supplied by GitHub Actions through IMAGE_TAG.
API_IMAGE=ghcr.io/your-org/betterspend-api
WEB_IMAGE=ghcr.io/your-org/betterspend-web
MIGRATOR_IMAGE=ghcr.io/your-org/betterspend-migrator

# Database
POSTGRES_USER=betterspend
POSTGRES_PASSWORD=change-me
POSTGRES_DB=betterspend
DATABASE_URL=postgresql://betterspend:change-me@postgres:5432/betterspend

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# S3-compatible object storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=betterspend
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=betterspend
MINIO_REGION=us-east-1
MINIO_ROOT_USER=betterspend
MINIO_ROOT_PASSWORD=change-me

# Auth and encryption
BETTER_AUTH_SECRET=change-me-use-openssl-rand-hex-32
AI_CREDENTIAL_ENCRYPTION_KEY=change-me-use-openssl-rand-base64-32

# App URLs
API_PORT=4001
API_URL=https://example.com
WEB_URL=https://example.com
NEXT_PUBLIC_API_URL=https://example.com
